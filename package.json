    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}