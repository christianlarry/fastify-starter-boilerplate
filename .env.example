# --- App ---
NODE_ENV=development

APP_NAME=Application Name
APP_PORT=3000
API_PREFIX=api
FRONTEND_DOMAIN=http://localhost:5173
BACKEND_DOMAIN=http://localhost:3000
DOCS_URL=http://localhost:3000/docs
CORS_ORIGIN=http://localhost:5173
COOKIE_SECRET=your-secret-key

# --- Rate Limit ---
# RATE_LIMIT=10 # number of requests
# RATE_LIMIT_TTL=60000 # in milliseconds

# --- Auth ---
# ACCESS_TOKEN_EXPIRATION_MINUTES=15
# REFRESH_TOKEN_EXPIRATION_DAYS=30
# VERIFICATION_TOKEN_EXPIRATION_HOURS=24
# FORGOT_PASSWORD_TOKEN_EXPIRATION_HOURS=1

# ACCESS_TOKEN_SECRET=your_access_token_secret_key
# REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
# VERIFICATION_TOKEN_SECRET=your_verification_token_secret_key
# FORGOT_PASSWORD_TOKEN_SECRET=your_forgot_password_token_secret_key

# --- PostgreSQL (local via docker-compose) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# DATABASE_URL=postgresql://keramik:keramik_password@localhost:5432/keramik?schema=public

# --- Redis (local via docker-compose) ---
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# --- Storage ---
# local | s3
# STORAGE_PROVIDER=local

# If STORAGE_PROVIDER=s3 (optional)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Google OAuth2
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Facebook OAuth2
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret
# FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback

# --- Email (using Mailtrap for development) ---
# MAIL_PORT=587
# MAIL_HOST=smtp.mailtrap.io
# MAIL_USER=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password
# MAIL_DEFAULT_NAME=RAG Keramik Support
# MAIL_DEFAULT_EMAIL=your_default_email@example.com
# MAIL_IGNORE_TLS=false
# MAIL_SECURE=false
# MAIL_REQUIRE_TLS=false

# Elasticsearch (local via docker-compose)
# ELASTICSEARCH_NODE=http://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_REQUEST_TIMEOUT=30000
# ELASTICSEARCH_MAX_RETRIES=3
# ELASTICSEARCH_COMPRESSION=true
# ELASTICSEARCH_TLS_REJECT_UNAUTHORIZED=false